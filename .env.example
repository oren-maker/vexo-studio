# --- Database ---
DATABASE_URL=postgresql://vexo:vexo@localhost:5432/vexo_studio?schema=public

# --- Redis / Queue ---
REDIS_URL=redis://localhost:6379

# --- Auth / JWT ---
JWT_ACCESS_SECRET=replace-me-access-secret
JWT_REFRESH_SECRET=replace-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# --- Encryption (AES-256-GCM, 32-byte hex) ---
ENCRYPTION_KEY=replace-with-64-hex-chars

# --- API ---
API_PORT=4000
API_BASE_URL=http://localhost:4000
WEB_BASE_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# --- S3-Compatible Storage ---
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=vexo-assets
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PRESIGNED_TTL_SECONDS=86400

# --- Provider Stubs (enable as needed) ---
FAL_API_KEY=
ELEVENLABS_API_KEY=
SUNO_API_KEY=
OPENAI_API_KEY=

# --- YouTube OAuth ---
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:4000/api/integrations/youtube/callback

# --- Notifications ---
WHATSAPP_SYSTEM_NUMBER=

# --- Seed (super admin) ---
SEED_ADMIN_EMAIL=admin@vexo.studio
SEED_ADMIN_PASSWORD=Vexo@2025!
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_FULLNAME=Super Admin
