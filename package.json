{
  "name": "vexo-studio",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:*",
    "dev:api": "npm --workspace @vexo/api run dev",
    "dev:web": "npm --workspace @vexo/web run dev",
    "dev:worker": "npm --workspace @vexo/worker run dev",
    "build": "npm-run-all build:*",
    "build:db": "npm --workspace @vexo/db run build",
    "build:shared": "npm --workspace @vexo/shared run build",
    "build:api": "npm --workspace @vexo/api run build",
    "build:web": "npm --workspace @vexo/web run build",
    "build:worker": "npm --workspace @vexo/worker run build",
    "db:migrate": "npm --workspace @vexo/db run migrate",
    "db:generate": "npm --workspace @vexo/db run generate",
    "db:seed": "npm --workspace @vexo/db run seed",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20"
  }
}
