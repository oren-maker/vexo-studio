// ----- Daily Brain Cache (self-improving meta-learning) -----
// Each day, a cron writes a snapshot: who am I, what did I learn today, what should I focus on tomorrow.
// Built by reading the previous N days of caches + current corpus state (prompts + guides) and sending
// to Gemini 2.5 Pro for synthesis. The identity grows over time.

model DailyBrainCache {
  id   String   @id @default(cuid())
  date DateTime @unique // truncated to day (YYYY-MM-DD 00:00:00 UTC)

  // Stat snapshot at boot-up
  totalPrompts    Int
  totalGuides     Int
  totalNodes      Int
  totalEmbeddings Int @default(0)

  // Daily deltas
  promptsAddedToday Int @default(0)
  guidesAddedToday  Int @default(0)
  upgradesToday     Int @default(0)
  imagesGenToday    Int @default(0)
  videosGenToday    Int @default(0)

  // Synthesis from Gemini Pro
  identity       String  @db.Text // "Today I am ___" (1 paragraph in Hebrew)
  todayLearnings Json // [{topic, insight, evidence}]
  tomorrowFocus  Json // [{priority, action, why}]
  weeklyArc      String? @db.Text // narrative of the past 7 days

  // Self-rated metrics
  maturityScore Float? // 1-10 from Gemini's eval

  createdAt DateTime @default(now())

  @@index([date])
}

model BrainChat {
  id           String         @id @default(cuid())
  title        String? // auto-generated from first message, first 60 chars
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  messages     BrainMessage[]
  summarizedAt DateTime? // set when the daily brain has read this chat
  summary      String?        @db.Text // constructive notes the brain extracted

  @@index([createdAt])
  @@index([summarizedAt])
}

model BrainUpgradeRequest {
  id            String    @id @default(cuid())
  chatId        String?
  messageId     String? // the original user message id
  instruction   String    @db.Text // what the user said to improve
  context       String?   @db.Text // brain's interpretation of WHY
  status        String    @default("pending") // pending | in-progress | done | rejected
  priority      Int       @default(3) // 1 (high) - 5 (low)
  claudeNotes   String?   @db.Text // Claude's notes after implementing
  implementedAt DateTime?
  createdAt     DateTime  @default(now())

  @@index([status])
  @@index([createdAt])
}

model BrainMessage {
  id        String    @id @default(cuid())
  chatId    String
  chat      BrainChat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  role      String // "user" | "brain"
  content   String    @db.Text
  createdAt DateTime  @default(now())

  @@index([chatId, createdAt])
}

// ActionOutcome — calibration dataset. Every brain action execute attempt logs
// a row so we can compute Expected Calibration Error (ECE): does "confidence
// 0.85" actually correspond to 85% accept rate? Bucketed analysis lives on
// /learn/insights (calibration panel).
model ActionOutcome {
  id         String   @id @default(cuid())
  chatId     String?
  actionType String // "compose_prompt" | "generate_video" | ...
  confidence Float? // 0–1, null if action had no confidence field
  outcome    String // "accepted" | "rejected" | "error" | "aborted-low-confidence"
  errorMsg   String?  @db.Text // first 500 chars of the error if any
  durationMs Int? // wall-clock of execute handler
  sceneId    String? // if action was scoped to a scene
  meta       Json? // arbitrary extras (e.g. which params were supplied)
  createdAt  DateTime @default(now())

  @@index([actionType, createdAt])
  @@index([outcome, createdAt])
}
