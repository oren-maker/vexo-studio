// VEXO Studio — Prisma schema (v2, multi-tenant)
// Source of truth: docs/SPEC.md

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// =====================================================================
// Enums
// =====================================================================

enum ContentType {
  SERIES
  COURSE
  KIDS_CONTENT
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum AIMode {
  MANUAL
  ASSISTED
  AUTOPILOT
}

enum EpisodeStatus {
  DRAFT
  PLANNING
  IN_PRODUCTION
  REVIEW
  READY_FOR_PUBLISH
  PUBLISHED
  ARCHIVED
}

enum SceneStatus {
  DRAFT
  PLANNING
  STORYBOARD_GENERATING
  STORYBOARD_REVIEW
  STORYBOARD_APPROVED
  VIDEO_GENERATING
  VIDEO_REVIEW
  APPROVED
  LOCKED
}

enum OrgPlan {
  FREE
  PRO
  STUDIO
  ENTERPRISE
}

// =====================================================================
// 1. Organizations
// =====================================================================

model Organization {
  id                String   @id @default(cuid())
  name              String
  slug              String   @unique
  plan              OrgPlan  @default(FREE)
  isActive          Boolean  @default(true)
  maxProjects       Int      @default(1)
  maxEpisodes       Int      @default(3)
  whitelabelEnabled Boolean  @default(false)
  customDomain      String?
  logoUrl           String?
  primaryColor      String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  users            OrganizationUser[]
  projects         Project[]
  providers        Provider[]
  apiKeys          ApiKey[]
  notifications    NotificationEvent[]
  webhookEndpoints WebhookEndpoint[]
  channels         ChannelIntegration[]
}

model OrganizationUser {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  roleId         String
  isOwner        Boolean  @default(false)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])
  role         Role         @relation(fields: [roleId], references: [id])

  @@unique([organizationId, userId])
  @@index([userId])
}

// =====================================================================
// 2. Users & Auth
// =====================================================================

model User {
  id             String    @id @default(cuid())
  fullName       String
  email          String    @unique
  username       String    @unique
  passwordHash   String
  isActive       Boolean   @default(true)
  totpSecret     String?
  totpEnabled    Boolean   @default(false)
  totpVerifiedAt DateTime?
  language       String    @default("en")
  lastLoginAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  sessions        UserSession[]
  auditLogs       AuditLog[]
  organizations   OrganizationUser[]
  notifications   NotificationEvent[]
  comments        SceneComment[]
  taskAssignments TaskAssignment[]
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?

  permissions RolePermission[]
  orgUsers    OrganizationUser[]
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique
  description String?
  roles       RolePermission[]
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
}

model UserSession {
  id               String   @id @default(cuid())
  userId           String
  refreshTokenHash String
  expiresAt        DateTime
  ipAddress        String?
  userAgent        String?
  deviceName       String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String
  actorUserId    String
  entityType     String
  entityId       String
  action         String
  oldValue       Json?
  newValue       Json?
  ipAddress      String?
  createdAt      DateTime @default(now())

  actor User @relation(fields: [actorUserId], references: [id])

  @@index([organizationId, createdAt])
  @@index([entityType, entityId])
}

// =====================================================================
// 3. 2FA / TOTP
// =====================================================================

model TotpChallenge {
  id        String   @id @default(cuid())
  userId    String
  token     String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

// =====================================================================
// 4. API Keys
// =====================================================================

model ApiKey {
  id              String    @id @default(cuid())
  organizationId  String
  name            String
  keyHash         String    @unique
  keyPrefix       String
  scopes          Json
  lastUsedAt      DateTime?
  expiresAt       DateTime?
  isActive        Boolean   @default(true)
  createdByUserId String
  createdAt       DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

// =====================================================================
// 5. Webhook Endpoints (outbound)
// =====================================================================

model WebhookEndpoint {
  id             String   @id @default(cuid())
  organizationId String
  url            String
  secret         String
  events         Json
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  organization Organization      @relation(fields: [organizationId], references: [id])
  deliveries   WebhookDelivery[]
}

model WebhookDelivery {
  id             String    @id @default(cuid())
  endpointId     String
  eventType      String
  payload        Json
  responseStatus Int?
  responseBody   String?
  attemptCount   Int       @default(1)
  success        Boolean   @default(false)
  deliveredAt    DateTime?
  createdAt      DateTime  @default(now())

  endpoint WebhookEndpoint @relation(fields: [endpointId], references: [id])

  @@index([endpointId, createdAt])
}

// =====================================================================
// 6. In-App Notifications
// =====================================================================

model NotificationEvent {
  id             String    @id @default(cuid())
  organizationId String
  userId         String
  type           String
  title          String
  body           String
  entityType     String?
  entityId       String?
  isRead         Boolean   @default(false)
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@index([organizationId, createdAt])
}

// =====================================================================
// 7. Providers & Wallets
// =====================================================================

model Provider {
  id              String   @id @default(cuid())
  organizationId  String
  name            String
  category        String
  apiUrl          String?
  apiKeyEncrypted String?
  isActive        Boolean  @default(true)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id])
  wallet       CreditWallet?
  alertRules   AlertRule[]

  @@index([organizationId])
}

model CreditWallet {
  id                       String   @id @default(cuid())
  providerId               String   @unique
  totalCreditsAdded        Float    @default(0)
  availableCredits         Float    @default(0)
  reservedCredits          Float    @default(0)
  lowBalanceThreshold      Float?
  criticalBalanceThreshold Float?
  isTrackingEnabled        Boolean  @default(true)
  notes                    String?
  updatedAt                DateTime @updatedAt

  provider     Provider            @relation(fields: [providerId], references: [id])
  transactions CreditTransaction[]
}

model CreditTransaction {
  id              String   @id @default(cuid())
  walletId        String
  transactionType String
  amount          Float
  unitType        String
  sourceType      String
  description     String?
  createdByUserId String?
  referenceId     String?
  createdAt       DateTime @default(now())

  wallet CreditWallet @relation(fields: [walletId], references: [id])

  @@index([walletId, createdAt])
}

model AlertRule {
  id                   String   @id @default(cuid())
  providerId           String
  alertType            String
  thresholdValue       Float?
  whatsappSystemNumber String?
  targetPhone          String?
  isEnabled            Boolean  @default(true)
  cooldownMinutes      Int      @default(60)
  createdAt            DateTime @default(now())

  provider Provider     @relation(fields: [providerId], references: [id])
  events   AlertEvent[]
}

model AlertEvent {
  id              String    @id @default(cuid())
  ruleId          String
  title           String
  message         String
  status          String
  deliveryChannel String
  sentAt          DateTime?
  createdAt       DateTime  @default(now())

  rule AlertRule @relation(fields: [ruleId], references: [id])
}

// =====================================================================
// 8. Incoming Webhook Receiver
// =====================================================================

model IncomingWebhook {
  id         String   @id @default(cuid())
  providerId String
  eventType  String
  payload    Json
  signature  String?
  verified   Boolean  @default(false)
  processed  Boolean  @default(false)
  jobId      String?
  createdAt  DateTime @default(now())

  @@index([providerId, processed])
}

// =====================================================================
// 9. Projects
// =====================================================================

model Project {
  id                          String        @id @default(cuid())
  organizationId              String
  name                        String
  contentType                 ContentType
  description                 String?
  language                    String        @default("he")
  targetAudience              String?
  status                      ProjectStatus @default(DRAFT)
  createdByUserId             String
  defaultDistributionPlatform String?       @default("YOUTUBE")
  studioOpeningEnabled        Boolean       @default(false)
  aiDirectorMode              AIMode        @default(MANUAL)
  autopilotEnabled            Boolean       @default(false)
  thumbnailUrl                String?
  genreTag                    String?
  styleGuide                  Json?
  createdAt                   DateTime      @default(now())
  updatedAt                   DateTime      @updatedAt

  organization    Organization           @relation(fields: [organizationId], references: [id])
  settings        ProjectSettings?
  series          Series[]
  courses         Course[]
  characters      Character[]
  memories        ProjectMemory[]
  aiDirector      AIDirector?
  aiLogs          AILog[]
  distributions   ProjectDistribution[]
  costEntries     CostEntry[]
  revenueEntries  RevenueEntry[]
  revenueStreams  RevenueStream[]
  revenueSplits   RevenueSplit[]
  contentCalendar ContentCalendarEntry[]
  templates       ProjectTemplate[]

  @@index([organizationId, status])
}

model ProjectSettings {
  id                           String   @id @default(cuid())
  projectId                    String   @unique
  defaultQualityMode           String   @default("STANDARD")
  defaultResolution            String   @default("1080p")
  defaultAspectRatio           String   @default("16:9")
  defaultDurationPolicy        String   @default("FLEXIBLE")
  requireSceneApproval         Boolean  @default(true)
  lockNextSceneUntilApproved   Boolean  @default(false)
  lockNextEpisodeUntilApproved Boolean  @default(false)
  autoPublishEnabled           Boolean  @default(false)
  subtitlesEnabled             Boolean  @default(true)
  dubbingEnabled               Boolean  @default(false)
  lipSyncEnabled               Boolean  @default(false)
  criticEnabled                Boolean  @default(true)
  memoryEnabled                Boolean  @default(true)
  costStrategyEnabled          Boolean  @default(true)
  styleConsistencyEnabled      Boolean  @default(true)
  collaborationEnabled         Boolean  @default(true)
  seoOptimizerEnabled          Boolean  @default(false)
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id])
}

// =====================================================================
// 10. Series / Seasons / Episodes
// =====================================================================

model Series {
  id            String   @id @default(cuid())
  projectId     String
  title         String
  summary       String?
  genre         String?
  coverImageUrl String?
  totalSeasons  Int      @default(0)
  totalBudget   Float?
  plannedCost   Float?
  actualCost    Float    @default(0)
  tokenCost     Float    @default(0)
  serverCost    Float    @default(0)
  storageCost   Float    @default(0)
  manualCost    Float    @default(0)
  revenueTotal  Float    @default(0)
  profitTotal   Float    @default(0)
  roiPercent    Float?
  budgetStatus  String   @default("OK")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project Project  @relation(fields: [projectId], references: [id])
  seasons Season[]

  @@index([projectId])
}

model Season {
  id                    String   @id @default(cuid())
  seriesId              String
  seasonNumber          Int
  title                 String?
  description           String?
  totalEpisodes         Int      @default(0)
  targetDurationMinutes Int?
  releaseYear           Int?
  status                String   @default("DRAFT")
  actualCost            Float    @default(0)
  revenueTotal          Float    @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  series   Series    @relation(fields: [seriesId], references: [id])
  episodes Episode[]

  @@unique([seriesId, seasonNumber])
}

model Episode {
  id                    String        @id @default(cuid())
  seasonId              String
  episodeNumber         Int
  title                 String
  synopsis              String?
  targetDurationSeconds Int?
  status                EpisodeStatus @default(DRAFT)
  plannedBudget         Float?
  actualCost            Float         @default(0)
  tokenCost             Float         @default(0)
  manualCost            Float         @default(0)
  storageCost           Float         @default(0)
  serverCost            Float         @default(0)
  revenueTotal          Float         @default(0)
  youtubeUrl            String?
  youtubeVideoId        String?
  publishedAt           DateTime?
  scheduledPublishAt    DateTime?
  currentSceneIndex     Int           @default(0)
  exportStatus          String?
  previewVideoUrl       String?
  seoTitle              String?
  seoDescription        String?
  seoTags               Json?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  season             Season                 @relation(fields: [seasonId], references: [id])
  scenes             Scene[]
  musicTracks        MusicTrack[]
  subtitleTracks     SubtitleTrack[]
  dubbingTracks      DubbingTrack[]
  publishingJobs     PublishingJob[]
  analyticsSnapshots AnalyticsSnapshot[]
  criticReviews      AICriticReview[]
  recapCandidates    RecapCandidate[]
  thumbnailVariants  ThumbnailVariant[]
  calendarEntries    ContentCalendarEntry[]

  @@unique([seasonId, episodeNumber])
  @@index([seasonId, status])
}

// =====================================================================
// 11. Content Calendar
// =====================================================================

model ContentCalendarEntry {
  id          String    @id @default(cuid())
  projectId   String
  episodeId   String?
  lessonId    String?
  title       String
  scheduledAt DateTime
  publishedAt DateTime?
  platform    String
  status      String    @default("SCHEDULED")
  notes       String?
  createdAt   DateTime  @default(now())

  project Project  @relation(fields: [projectId], references: [id])
  episode Episode? @relation(fields: [episodeId], references: [id])

  @@index([projectId, scheduledAt])
}

// =====================================================================
// 12. A/B Thumbnail Testing
// =====================================================================

model ThumbnailVariant {
  id          String    @id @default(cuid())
  episodeId   String
  assetId     String
  label       String
  isActive    Boolean   @default(false)
  isWinner    Boolean   @default(false)
  impressions Int       @default(0)
  clickRate   Float?
  youtubeId   String?
  activatedAt DateTime?
  createdAt   DateTime  @default(now())

  episode Episode @relation(fields: [episodeId], references: [id])

  @@index([episodeId])
}

// =====================================================================
// 13. Course
// =====================================================================

model Course {
  id              String   @id @default(cuid())
  projectId       String
  title           String
  description     String?
  difficultyLevel String?
  durationMinutes Int?
  instructorType  String?
  actualCost      Float    @default(0)
  revenueTotal    Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project Project        @relation(fields: [projectId], references: [id])
  modules CourseModule[]
}

model CourseModule {
  id          String   @id @default(cuid())
  courseId    String
  title       String
  orderIndex  Int
  description String?
  createdAt   DateTime @default(now())

  course  Course   @relation(fields: [courseId], references: [id])
  lessons Lesson[]
}

model Lesson {
  id              String   @id @default(cuid())
  moduleId        String
  title           String
  summary         String?
  durationSeconds Int?
  status          String   @default("DRAFT")
  actualCost      Float    @default(0)
  revenueTotal    Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  module CourseModule @relation(fields: [moduleId], references: [id])
  scenes Scene[]
}

// =====================================================================
// 14. Scenes / Frames / Assets
// =====================================================================

model Scene {
  id                    String      @id @default(cuid())
  parentType            String
  parentId              String
  episodeId             String?
  lessonId              String?
  sceneNumber           Int
  title                 String?
  summary               String?
  scriptText            String?
  scriptSource          String?
  dialogueJson          Json?
  targetDurationSeconds Int?
  status                SceneStatus @default(DRAFT)
  plannedBudget         Float?
  actualCost            Float       @default(0)
  tokenCost             Float       @default(0)
  generationCost        Float       @default(0)
  manualCost            Float       @default(0)
  revisionCost          Float       @default(0)
  memoryContext         Json?
  styleConstraints      Json?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  episode         Episode?         @relation(fields: [episodeId], references: [id])
  lesson          Lesson?          @relation(fields: [lessonId], references: [id])
  frames          SceneFrame[]
  musicTracks     MusicTrack[]
  lipSyncJobs     LipSyncJob[]
  criticReviews   AICriticReview[]
  versions        SceneVersion[]
  comments        SceneComment[]
  taskAssignments TaskAssignment[]

  @@index([parentType, parentId])
}

model SceneFrame {
  id                String   @id @default(cuid())
  sceneId           String
  orderIndex        Int
  beatSummary       String?
  imagePrompt       String?
  negativePrompt    String?
  styleConstraints  String?
  generatedImageUrl String?
  approvedImageUrl  String?
  status            String   @default("PENDING")
  revisionCount     Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  scene Scene @relation(fields: [sceneId], references: [id])

  @@index([sceneId])
}

model Asset {
  id              String   @id @default(cuid())
  projectId       String
  entityType      String
  entityId        String
  assetType       String
  providerId      String?
  fileUrl         String
  originUrl       String?
  thumbnailUrl    String?
  mimeType        String?
  durationSeconds Float?
  sizeBytes       BigInt?
  metadata        Json?
  versionNumber   Int      @default(1)
  status          String   @default("READY")
  createdAt       DateTime @default(now())

  @@index([entityType, entityId])
  @@index([projectId, assetType])
}

model SceneVersion {
  id              String   @id @default(cuid())
  sceneId         String
  versionNumber   Int
  scriptSnapshot  String?
  promptSnapshot  Json?
  assetSnapshot   Json?
  reviewNotes     String?
  createdByUserId String?
  createdAt       DateTime @default(now())

  scene Scene @relation(fields: [sceneId], references: [id])

  @@index([sceneId])
}

// =====================================================================
// 15. Collaboration
// =====================================================================

model SceneComment {
  id         String    @id @default(cuid())
  sceneId    String
  userId     String
  frameId    String?
  body       String
  resolved   Boolean   @default(false)
  resolvedAt DateTime?
  resolvedBy String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  scene Scene @relation(fields: [sceneId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@index([sceneId])
}

model TaskAssignment {
  id          String    @id @default(cuid())
  sceneId     String?
  episodeId   String?
  assignedTo  String
  assignedBy  String
  taskType    String
  dueAt       DateTime?
  completedAt DateTime?
  status      String    @default("OPEN")
  notes       String?
  createdAt   DateTime  @default(now())

  scene Scene? @relation(fields: [sceneId], references: [id])
  user  User   @relation(fields: [assignedTo], references: [id])

  @@index([assignedTo, status])
}

// =====================================================================
// 16. Templates
// =====================================================================

model ProjectTemplate {
  id               String      @id @default(cuid())
  projectId        String?
  organizationId   String?
  name             String
  contentType      ContentType
  description      String?
  thumbnailUrl     String?
  episodeStructure Json?
  characterPresets Json?
  isPublic         Boolean     @default(false)
  isPremium        Boolean     @default(false)
  price            Float?
  usageCount       Int         @default(0)
  createdByUserId  String
  createdAt        DateTime    @default(now())

  project Project? @relation(fields: [projectId], references: [id])

  @@index([contentType, isPublic])
}

// =====================================================================
// 17. Characters & Voices
// =====================================================================

model Character {
  id                String   @id @default(cuid())
  projectId         String
  name              String
  roleType          String?
  characterType     String?
  gender            String?
  ageRange          String?
  appearance        String?
  personality       String?
  wardrobeRules     String?
  speechStyle       String?
  continuityLock    Boolean  @default(false)
  personalityPrompt String?
  behaviorPrompt    String?
  visualFingerprint Json?
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  project Project          @relation(fields: [projectId], references: [id])
  media   CharacterMedia[]
  voices  CharacterVoice[]

  @@index([projectId])
}

model CharacterMedia {
  id               String   @id @default(cuid())
  characterId      String
  mediaType        String
  fileUrl          String
  thumbnailUrl     String?
  sourceProviderId String?
  metadata         Json?
  createdAt        DateTime @default(now())

  character Character @relation(fields: [characterId], references: [id])
}

model CharacterVoice {
  id          String   @id @default(cuid())
  characterId String
  providerId  String
  voiceModel  String
  language    String   @default("he")
  tone        String?
  pitch       Float?
  speed       Float?
  createdAt   DateTime @default(now())

  character Character @relation(fields: [characterId], references: [id])
}

// =====================================================================
// 18. Music / Subtitles / Dubbing / Lip Sync
// =====================================================================

model MusicTrack {
  id              String   @id @default(cuid())
  entityType      String
  entityId        String
  episodeId       String?
  sceneId         String?
  trackType       String
  sourceType      String
  providerId      String?
  prompt          String?
  mood            String?
  durationSeconds Float?
  fileUrl         String?
  status          String   @default("PENDING")
  createdAt       DateTime @default(now())

  episode Episode? @relation(fields: [episodeId], references: [id])
  scene   Scene?   @relation(fields: [sceneId], references: [id])

  @@index([entityType, entityId])
}

model SubtitleTrack {
  id              String   @id @default(cuid())
  entityType      String
  entityId        String
  episodeId       String?
  language        String
  content         Json?
  isAutoGenerated Boolean  @default(true)
  status          String   @default("PENDING")
  createdAt       DateTime @default(now())

  episode Episode? @relation(fields: [episodeId], references: [id])

  @@index([entityType, entityId])
}

model DubbingTrack {
  id           String   @id @default(cuid())
  entityType   String
  entityId     String
  episodeId    String?
  language     String
  providerId   String?
  audioFileUrl String?
  synced       Boolean  @default(false)
  status       String   @default("PENDING")
  createdAt    DateTime @default(now())

  episode Episode? @relation(fields: [episodeId], references: [id])
}

model LipSyncJob {
  id                 String    @id @default(cuid())
  entityType         String
  entityId           String
  sceneId            String?
  providerId         String?
  sourceVideoAssetId String?
  sourceAudioAssetId String?
  outputAssetId      String?
  status             String    @default("PENDING")
  actualCost         Float?
  createdAt          DateTime  @default(now())
  completedAt        DateTime?

  scene Scene? @relation(fields: [sceneId], references: [id])
}

// =====================================================================
// 19. AI Director / Critic / Memory / Style Engine
// =====================================================================

model AIDirector {
  id                 String    @id @default(cuid())
  projectId          String    @unique
  mode               AIMode    @default(MANUAL)
  learningEnabled    Boolean   @default(false)
  experienceScore    Float     @default(0)
  autopilotEnabled   Boolean   @default(false)
  lastTrainingUpdate DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id])
}

model AILog {
  id             String   @id @default(cuid())
  projectId      String
  actorType      String
  actionType     String
  input          Json?
  output         Json?
  decisionReason String?
  successScore   Float?
  cost           Float?
  createdAt      DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])

  @@index([projectId, createdAt])
}

model AICriticReview {
  id             String   @id @default(cuid())
  entityType     String
  entityId       String
  episodeId      String?
  sceneId        String?
  contentType    String
  score          Float
  feedback       String?
  issuesDetected Json?
  suggestions    Json?
  createdAt      DateTime @default(now())

  episode Episode? @relation(fields: [episodeId], references: [id])
  scene   Scene?   @relation(fields: [sceneId], references: [id])

  @@index([entityType, entityId])
}

model ProjectMemory {
  id               String   @id @default(cuid())
  projectId        String
  memoryType       String
  title            String
  content          Json
  sourceEntityType String?
  sourceEntityId   String?
  importanceScore  Float    @default(0.5)
  createdAt        DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])

  @@index([projectId, memoryType])
}

model StyleConsistencySnapshot {
  id            String   @id @default(cuid())
  projectId     String
  episodeId     String?
  sceneId       String?
  colorPalette  Json?
  lightingNotes String?
  cameraStyle   String?
  prompt        String?
  createdAt     DateTime @default(now())

  @@index([projectId])
}

model RecapCandidate {
  id         String   @id @default(cuid())
  projectId  String
  episodeId  String
  assetId    String?
  recapScore Float
  reason     String?
  createdAt  DateTime @default(now())

  episode Episode @relation(fields: [episodeId], references: [id])

  @@index([projectId])
}

model ScriptBreakdown {
  id             String   @id @default(cuid())
  sceneId        String   @unique
  characters     Json
  locations      Json
  props          Json
  toneAnalysis   String?
  dialogueParsed Json?
  generatedAt    DateTime @default(now())
}

// =====================================================================
// 20. Distribution / Analytics / Finance
// =====================================================================

model ChannelIntegration {
  id                    String    @id @default(cuid())
  organizationId        String
  provider              String
  channelName           String
  channelId             String
  accessTokenEncrypted  String
  refreshTokenEncrypted String?
  tokenExpiry           DateTime?
  isActive              Boolean   @default(true)
  createdByUserId       String
  createdAt             DateTime  @default(now())

  organization   Organization          @relation(fields: [organizationId], references: [id])
  distributions  ProjectDistribution[]
  publishingJobs PublishingJob[]

  @@index([organizationId])
}

model ProjectDistribution {
  id                   String   @id @default(cuid())
  projectId            String
  platform             String
  channelIntegrationId String
  publishingMode       String   @default("MANUAL")
  autoPublishEnabled   Boolean  @default(false)
  defaultPrivacy       String   @default("PRIVATE")
  defaultCategory      String?
  defaultTags          Json?
  defaultLanguage      String?
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())

  project     Project            @relation(fields: [projectId], references: [id])
  integration ChannelIntegration @relation(fields: [channelIntegrationId], references: [id])
}

model PublishingJob {
  id                         String    @id @default(cuid())
  entityType                 String
  entityId                   String
  episodeId                  String?
  platform                   String
  channelIntegrationId       String
  title                      String
  description                String?
  tags                       Json?
  thumbnailAssetId           String?
  selectedThumbnailVariantId String?
  outputUrl                  String?
  externalId                 String?
  status                     String    @default("PENDING")
  scheduledAt                DateTime?
  publishedAt                DateTime?
  createdAt                  DateTime  @default(now())

  integration ChannelIntegration @relation(fields: [channelIntegrationId], references: [id])
  episode     Episode?           @relation(fields: [episodeId], references: [id])

  @@index([entityType, entityId])
}

model AnalyticsSnapshot {
  id                         String   @id @default(cuid())
  entityType                 String
  entityId                   String
  episodeId                  String?
  platform                   String
  views                      Int      @default(0)
  likes                      Int      @default(0)
  comments                   Int      @default(0)
  shares                     Int      @default(0)
  subscribersGained          Int      @default(0)
  watchTimeSeconds           Int      @default(0)
  averageViewDurationSeconds Float?
  dropOffPoints              Json?
  sentimentScore             Float?
  revenueAmount              Float?
  capturedAt                 DateTime @default(now())

  episode Episode? @relation(fields: [episodeId], references: [id])

  @@index([entityType, entityId, capturedAt])
}

model AudienceInsight {
  id             String   @id @default(cuid())
  projectId      String
  episodeId      String?
  insightType    String
  content        Json
  recommendation String?
  generatedAt    DateTime @default(now())

  @@index([projectId])
}

model CostEntry {
  id              String   @id @default(cuid())
  projectId       String?
  entityType      String
  entityId        String
  costCategory    String
  providerId      String?
  description     String?
  unitCost        Float
  quantity        Float    @default(1)
  totalCost       Float
  sourceType      String
  createdByUserId String?
  createdAt       DateTime @default(now())

  project Project? @relation(fields: [projectId], references: [id])

  @@index([entityType, entityId])
}

model RevenueEntry {
  id          String   @id @default(cuid())
  projectId   String?
  entityType  String
  entityId    String
  platform    String
  sourceType  String
  description String?
  amount      Float
  currency    String   @default("USD")
  occurredAt  DateTime
  createdAt   DateTime @default(now())

  project Project? @relation(fields: [projectId], references: [id])

  @@index([entityType, entityId])
}

model RevenueStream {
  id                  String   @id @default(cuid())
  projectId           String
  platform            String
  totalRevenue        Float    @default(0)
  adRevenue           Float    @default(0)
  subscriptionRevenue Float    @default(0)
  sponsorshipRevenue  Float    @default(0)
  otherRevenue        Float    @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id])
}

model RevenueSplit {
  id           String   @id @default(cuid())
  projectId    String
  entityType   String
  entityName   String
  percentage   Float
  payoutMethod String?
  notes        String?
  createdAt    DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])
}
