// =====================================================================
// VEXO-LEARN MIGRATION — 26 models ported from vexo-learn (2026-04-15)
// Brain chat, Guides, LearnSource, MergeJob (vexo-learn flavour),
// KnowledgeNode, SubscriberPrompt, etc. Auth swapped to vexo-studio JWT.
// =====================================================================

model LearnSource {
  id                String             @id @default(cuid())
  type              String // "instructor_url" | "cedance" | "free_api" | "upload"
  url               String?
  prompt            String
  title             String?
  thumbnail         String?
  duration          Int?
  blobUrl           String? // Vercel Blob URL or external MP4 URL
  externalId        String?            @unique
  status            String             @default("pending") // pending | processing | complete | failed
  error             String?
  addedBy           String?
  pdfBlobUrl        String?
  pdfGeneratedAt    DateTime?
  parentSourceId    String?
  parentSource      LearnSource?       @relation("Lineage", fields: [parentSourceId], references: [id], onDelete: SetNull)
  children          LearnSource[]      @relation("Lineage")
  lineageNotes      String? // what was borrowed/adapted from parent (short paragraph)
  userRating        Int? // 1-5 stars, manual quality rating
  viewCount         Int                @default(0)
  embedding         Float[] // gemini-embedding-001 vector for semantic search (default: empty)
  embeddingModel    String? // model used for the current embedding
  embeddedAt        DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  analysis          VideoAnalysis?
  subscriberPrompts SubscriberPrompt[]

  @@index([status])
  @@index([type])
  @@index([userRating])
  @@index([createdAt])
  @@index([parentSourceId])
  @@index([status, createdAt])
}

model VideoAnalysis {
  id              String          @id @default(cuid())
  sourceId        String          @unique
  source          LearnSource     @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  description     String
  techniques      String[]        @default([])
  howTo           String[]        @default([])
  tags            String[]        @default([])
  style           String?
  mood            String?
  difficulty      String?
  insights        String[]        @default([])
  promptAlignment Int?
  rawGemini       String
  createdAt       DateTime        @default(now())
  knowledgeNodes  KnowledgeNode[]
}

model KnowledgeNode {
  id             String        @id @default(cuid())
  type           String // "technique" | "style" | "how_to" | "insight"
  title          String
  body           String
  tags           String[]      @default([])
  confidence     Float         @default(0.8)
  analysisId     String
  analysis       VideoAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  sentToDirector Boolean       @default(false)
  createdAt      DateTime      @default(now())

  @@index([sentToDirector])
  @@index([type])
}

model BrainReference {
  id         String    @id @default(cuid())
  kind       String // "emotion" | "sound" | "cinematography" | "capability"
  name       String
  shortDesc  String
  longDesc   String
  tags       String[]  @default([])
  order      Int       @default(0)
  // Validity intervals (truth-history pattern from research)
  validFrom  DateTime  @default(now())
  validTo    DateTime? // null = currently valid
  supersedes String? // id of the BrainReference this replaces
  version    Int       @default(1)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  versions BrainReferenceVersion[]

  @@index([kind, order])
  @@index([validTo])
}

model BrainReferenceVersion {
  id          String   @id @default(cuid())
  referenceId String
  reference   BrainReference @relation(fields: [referenceId], references: [id], onDelete: Cascade)
  version     Int
  kind        String
  name        String
  shortDesc   String
  longDesc    String
  tags        String[] @default([])
  changedBy   String? // "user" | "brain-action" | "migration"
  reason      String? // optional free-text reason
  createdAt   DateTime @default(now())

  @@index([referenceId, version])
  @@index([createdAt])
}

model SubscriberPrompt {
