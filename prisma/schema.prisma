model MergeClip {
  id            String   @id @default(cuid())
  jobId         String
  job           MergeJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  blobUrl       String
  filename      String
  order         Int
  trimStart     Float?
  trimEnd       Float?
  transition    String? // null|fade|dissolve|cut � applied to the gap with the NEXT clip
  transitionDur Float?
  durationSec   Float?
  sizeBytes     Int?
